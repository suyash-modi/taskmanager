# Backend (copy to .env locally or set in Railway Variables)

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/taskdb
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# Must be at least 32 bytes for HS256; use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Comma-separated list, e.g. https://your-app.up.railway.app,http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional: for Railway production profile
# SPRING_PROFILES_ACTIVE=prod
